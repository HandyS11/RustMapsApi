# Roslynator

dotnet_analyzer_diagnostic.category-roslynator.severity = warning
roslynator_analyzers.enabled_by_default = true
roslynator_refactorings.enabled = true
roslynator_compiler_diagnostic_fixes.enabled = true

# Dotnet Diagnostic Rules

# https://learn.microsoft.com/en-us/dotnet/fundamentals/code-analysis/quality-rules/
dotnet_diagnostic.CA1002.severity = none # Do not expose generic lists — API uses List<T> intentionally for protobuf collections
dotnet_diagnostic.CA1008.severity = none # Enums should have zero value
dotnet_diagnostic.CA1031.severity = none # Do not catch general exception types (intentional for fail-safe CLI resilience)
dotnet_diagnostic.CA1054.severity = none # Uri parameters should not be strings — RustMaps map URLs are user-supplied strings
dotnet_diagnostic.CA1056.severity = none # Uri properties should not be strings
dotnet_diagnostic.CA2234.severity = none # Pass System.Uri — typed HttpClient uses relative path strings against a base address
dotnet_diagnostic.CA1303.severity = none # Do not pass literals as localized parameters (literal strings in console output — CLI tool not localized)
dotnet_diagnostic.CA1308.severity = none # Normalize strings to uppercase
dotnet_diagnostic.CS1574.severity = none # XML comment has cref attribute that could not be resolved (boring with {} generics)
dotnet_diagnostic.CA1707.severity = none # Identifiers should not contain underscores
dotnet_diagnostic.CA1708.severity = none # Identifiers should differ by more than case — proto field names (auth_service) are part of the wire contract
dotnet_diagnostic.CA1716.severity = none # Identifiers should not match keywords
dotnet_diagnostic.CA1806.severity = none # Ignore method results (not working properly on all cases)
dotnet_diagnostic.CA1819.severity = none # Properties should not return arrays — used for protobuf byte[] and RayData
dotnet_diagnostic.CA1003.severity = none # Use generic event handler — wrapping EventHandler<string/Exception/T> in EventArgs subclasses is a breaking public API change
dotnet_diagnostic.CA1062.severity = none # Validate parameters — nullable reference types provide equivalent compile-time null safety; runtime guards are redundant noise
dotnet_diagnostic.CA1848.severity = none # LoggerMessage source-gen is overkill for this bot's low-volume logging

dotnet_diagnostic.IDE0058.severity = none # Expression not used (boring with extension methods) _ = Foo()

dotnet_diagnostic.Moq1203.severity = none # Method setup should specify a return value
dotnet_diagnostic.Moq1400.severity = none # Choose a mock behaviour (strict, loose)
dotnet_diagnostic.Moq1410.severity = none # Set behaviour to Strict

dotnet_diagnostic.S2094.severity = none # Empty classes — intentional discriminated-union marker records (Marker/Note/EventArg hierarchies)

dotnet_diagnostic.T0003.severity = none # Do not use tuples
dotnet_diagnostic.T0006.severity = none # Do not use Helper in type name
dotnet_diagnostic.T0008.severity = none # Move methods before nested types
dotnet_diagnostic.T0010.severity = none # Use 'x' parameter for lambdas
dotnet_diagnostic.T0017.severity = none # CancellationToken should be named cancel
dotnet_diagnostic.T0019.severity = none # Indent ...
dotnet_diagnostic.T0025.severity = none # Indent ...
dotnet_diagnostic.T0026.severity = none # Indent ...
dotnet_diagnostic.T0029.severity = none # Indent ...
dotnet_diagnostic.T0043.severity = none # Do not use primary constructors
dotnet_diagnostic.T0046.severity = none # Better name extension classes

# ReSharper-specific rules
resharper_convert_if_statement_to_return_statement_highlighting = none
resharper_convert_to_extension_block_highlighting = none
resharper_unused_auto_property_accessor_global_highlighting = none

# ReSharper formatting — align with dotnet format to prevent CI drift
resharper_wrap_object_and_collection_initializer_style = chop_if_long
resharper_place_simple_initializer_on_single_line = false
resharper_wrap_linq_expressions = chop_always
resharper_csharp_wrap_parameters_style = chop_if_long
resharper_csharp_place_method_parameter_on_same_line = false

[**/Migrations/*.cs]
generated_code = true
dotnet_diagnostic.CS1591.severity = none # XML docs not required in generated migrations
dotnet_diagnostic.IDE0005.severity = none # Remove unnecessary using directives

dotnet_diagnostic.S4581.severity = none # Use Guid.Empty

dotnet_diagnostic.T0001.severity = none # Use file scoped namespaces
dotnet_diagnostic.T0041.severity = none # Use string literal for multiline strings

[**/Models/*.cs]
dotnet_diagnostic.CA2227.severity = none # Collection properties should be read-only

[**/*Tests*/**.cs]
dotnet_diagnostic.CA1309.severity = none # Use ordinal string comparison (not suitable for testing gridify sorting)
dotnet_diagnostic.CA1307.severity = none # StringComparison overload not necessary for test assertions
dotnet_diagnostic.CA2263.severity = none # Non-generic JsonSerializer overload is fine in tests
dotnet_diagnostic.CA1515.severity = none # Application API means internal classes
dotnet_diagnostic.CS1591.severity = none # Missing XML comment for publicly visible type or member
dotnet_diagnostic.CA2000.severity = none # Using statement required for IDisposable
dotnet_diagnostic.CA2007.severity = none # Consider calling ConfigureAwait on the awaited task
dotnet_diagnostic.CA1859.severity = none # Interface references are intentional in tests (exercise the contract)

dotnet_diagnostic.IDE1006.severity = none # Naming rule for test classes

dotnet_diagnostic.S3220.severity = none # Partial match for parameters (params)

dotnet_diagnostic.xUnit1042.severity = none # object[] are okay for MemberData
dotnet_diagnostic.xUnit1044.severity = none # Object might be serializable (bullshit)
dotnet_diagnostic.xUnit1045.severity = none # Object might be serializable (bullshit)

[samples/**]
generated_code = true
dotnet_diagnostic.CA2007.severity = none # ConfigureAwait not required in console-app entry points
dotnet_diagnostic.CS1591.severity = none # XML docs not required in sample apps

[tests/**]
dotnet_diagnostic.CA2007.severity = none # ConfigureAwait not required in test projects
dotnet_diagnostic.CS1591.severity = none # XML docs not required in test projects
dotnet_diagnostic.VSTHRD003.severity = none # Awaiting stored Task fields is acceptable in test infrastructure

[tools/**]
dotnet_diagnostic.CS1591.severity = none # XML docs not required in internal tooling
