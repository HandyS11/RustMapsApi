{
  "metadata": [
    {
      "src": [
        {
          "src": "../src",
          "files": [ "**/*.csproj" ]
        }
      ],
      "dest": "api",
      "filter": "filterConfig.yml",
      "properties": {
        "TargetFramework": "net10.0"
      }
    }
  ],
  "build": {
    "content": [
      { "files": [ "**/*.{md,yml}" ], "exclude": [ "_site/**", "template/**", "superpowers/**", "product/**", "README.md", "filterConfig.yml" ] }
    ],
    "resource": [
      {
        "files": [
          "images/**"
        ]
      }
    ],
    "globalMetadata": {
      "_appName": "RustMapsApi",
      "_appTitle": "RustMapsApi",
      "_appFaviconPath": "images/fav-icon.png",
      "_appLogoPath": "images/fav-icon.png",
      "_appFooter": "<span>RustMapsApi — a C# client for the RustMaps API v4. MIT licensed. <a href=\"https://github.com/HandyS11/RustMapsApi\">GitHub</a> · <a href=\"https://www.nuget.org/packages/RustMapsApi\">NuGet</a></span>",
      "_enableSearch": true,
      "_enableNewTab": true,
      "_disableContribution": false,
      "_gitContribute": {
        "repo": "https://github.com/HandyS11/RustMapsApi",
        "branch": "develop",
        "apiSpecFolder": "docs/api"
      },
      "pdf": false
    },
    "template": [
      "default",
      "modern",
      "template"
    ],
    "dest": "_site"
  }
}
